{
  "schema_version": "dahash.file_converters/v1",
  "converters": [
    {
      "id": "pkcs12-pfx-john",
      "extensions": [
        ".p12",
        ".pfx"
      ],
      "tools": [
        {
          "name": "pfx2john.py",
          "args": [
            "{file}"
          ],
          "expected_hash_types": [
            "pfx-pkcs-12-pbe-sha1-sha2"
          ]
        }
      ],
      "notes": "PKCS#12 certificate bundles are explicit .p12/.pfx inputs for pfx2john.py."
    },
    {
      "id": "7zip-john",
      "extensions": [
        ".7z"
      ],
      "tools": [
        {
          "name": "7z2john.pl",
          "args": [
            "{file}"
          ],
          "expected_hash_types": [
            "7-zip"
          ]
        }
      ],
      "notes": "7-Zip archives have an explicit 7z2john converter."
    },
    {
      "id": "zip-john",
      "extensions": [
        ".zip",
        ".zipx"
      ],
      "tools": [
        {
          "name": "zip2john",
          "args": [
            "{file}"
          ],
          "expected_hash_types": [
            "pkzip-compressed",
            "pkzip-compressed-multi-file",
            "pkzip-master-key",
            "pkzip-master-key-6-byte-optimization",
            "pkzip-mixed-multi-file",
            "pkzip-mixed-multi-file-checksum-only",
            "pkzip-uncompressed",
            "securezip-aes-128",
            "securezip-aes-192",
            "securezip-aes-256",
            "winzip",
            "zipmonster"
          ]
        }
      ],
      "notes": "ZIP/ZIPX archives have explicit John conversion helpers; generic text files are intentionally excluded."
    },
    {
      "id": "rar-john",
      "extensions": [
        ".rar"
      ],
      "tools": [
        {
          "name": "rar2john",
          "args": [
            "{file}"
          ],
          "expected_hash_types": [
            "rar3-hp",
            "rar3-p-compressed",
            "rar3-p-uncompressed",
            "rar5"
          ]
        }
      ],
      "notes": "RAR archives have explicit John conversion helpers."
    },
    {
      "id": "pdf-john",
      "extensions": [
        ".pdf"
      ],
      "tools": [
        {
          "name": "pdf2john.py",
          "args": [
            "{file}"
          ]
        },
        {
          "name": "pdf2john.pl",
          "args": [
            "{file}"
          ]
        }
      ],
      "notes": "PDF files can be converted with pdf2john helpers; both Python and Perl variants are tried when present."
    },
    {
